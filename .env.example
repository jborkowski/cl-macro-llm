# Copy to `.env` and fill in. The launcher (`scripts/cloud/launch.sh`)
# sources `.env`, configures runpodctl with your personal API key, and
# verifies the authenticated user matches RUNPOD_EXPECTED_EMAIL before
# booting a pod — so you can't accidentally launch on a company account.

# ── RunPod (required by launch.sh) ──────────────────────────────────
RUNPOD_API_KEY=rpa_xxx
RUNPOD_EXPECTED_EMAIL=you@personal-email.com

# ── HuggingFace (required by run.sh on the pod) ─────────────────────
HF_TOKEN=hf_xxx

# Optional — set to enable adapter auto-upload after training.
# IMPORTANT: launch.sh refuses to boot without HF_REPO (unless KEEP_POD=1),
# because the adapter would otherwise vanish when the pod is torn down.
HF_REPO=j14i/cl-macro-27b-lora

# Optional — Weights & Biases for live training curves
# WANDB_API_KEY=xxx

# Optional — override training defaults
# BASE_MODEL=Qwen/Qwen3.6-27B
# DATASET=j14i/cl-macros-thinking
# MAX_SEQ_LENGTH=4096
