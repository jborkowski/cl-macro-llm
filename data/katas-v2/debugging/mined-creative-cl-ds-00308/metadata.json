  "reference_defmacro": "(defmacro with-instrumentation (name &body body)\n  (let ((n (gensym)) (r (gensym)))\n    `(let ((,n ,name))\n       (format *trace-output* \"~&ENTER ~A~%\" ,n)\n       (let ((,r (progn ,@body)))\n         (format *trace-output* \"~&EXIT ~A => ~S~%\" ,n ,r)\n         ,r))))",
